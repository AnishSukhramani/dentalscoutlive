# Gmail App Password for Email Sending
# Replace YOUR_16_CHARACTER_APP_PASSWORD with your actual Gmail app password
GMAIL_APP_PASSWORD=YOUR_16_CHARACTER_APP_PASSWORD

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Reply sync: uses ALL users from data/user.json. Each user's password is resolved from env.
# e.g. user.json has "password": "process.env.GMAIL_APP_PASSWORD" -> use GMAIL_APP_PASSWORD below.
# IMAP host is auto-inferred from email domain (Gmail, Outlook, Yahoo, or imap.gmail.com for custom domains).
# Add GMAIL_APP_PASSWORD_2, GMAIL_APP_PASSWORD_3, etc. for each additional inbox in user.json.
GMAIL_APP_PASSWORD_2=...
GMAIL_APP_PASSWORD_3=...
GMAIL_APP_PASSWORD_4=...
# (etc. for each user in user.json)

# Google Sheets API Configuration (for Agentic Call export)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here

# Campaign progression cron (daily 9 PM IST)
# Set CRON_SECRET and use the same value in GitHub Actions secrets for the workflow that calls /api/cron/campaign-progression.
CRON_SECRET=your_cron_secret_here
CRON_SENDER_EMAIL=your_sender_email_for_automated_campaign_emails
CRON_SENDER_NAME=Campaign
# Optional: base URL for self-calls (sync + process queue). Defaults to VERCEL_URL on Vercel.
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# Auth (self-built DB-backed)
# Generate a random string: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Signup restrictions (internal app - company only)
# Comma-separated domains, e.g. neuralityhealth.ai
SIGNUP_ALLOWED_DOMAINS=neuralityhealth.ai
# Secret token required to create an account (share internally only)
SIGNUP_ACCESS_TOKEN=your_signup_token_here

# Other environment variables can be added here
# DATABASE_URL=your_database_url
# API_KEY=your_api_key